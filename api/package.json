{
  "name": "pokemon-detective-api",
  "private": true,
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "~5.7.0"
  },
  "scripts": {
    "build:handler": "esbuild src/handler.ts --bundle --platform=node --target=node22 --out-extension:.js=.cjs --outfile=dist/handler.cjs",
    "build:authorizer": "esbuild src/authorizer.ts --bundle --platform=node --target=node22 --outfile=dist/authorizer.js",
    "dev:server": "npm run build:handler && node dev-server.js",
    "build:handler:zip": "npm run build:handler && cp dist/handler.cjs dist/handler.js && cd dist && zip -r handler.zip handler.js"
  }
}
